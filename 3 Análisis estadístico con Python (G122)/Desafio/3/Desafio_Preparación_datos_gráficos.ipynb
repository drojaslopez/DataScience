    "\n",
    "# Configurar el gráfico\n",
    "plt.title('Physicians per Thousand vs Life Expectancy', fontsize=16, fontweight='bold')\n",
    "plt.xlabel('Países ordenados por Life Expectancy', fontsize=12)\n",
    "plt.ylabel('Valores', fontsize=12)\n",
    "plt.legend(fontsize=12)\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Alternativa: Gráfico con dos ejes Y (escalas diferentes)\n",
    "fig, ax1 = plt.subplots(figsize=(12, 6))\n",
    "\n",
    "# Eje Y izquierdo para Life expectancy\n",
    "ax1.plot(range(len(df_ordenado)), df_ordenado['Life expectancy'], \n",
    "         color='blue', linewidth=2, marker='o', markersize=4, alpha=0.7)\n",
    "ax1.set_xlabel('Países ordenados por Life Expectancy', fontsize=12)\n",
    "ax1.set_ylabel('Life Expectancy (años)', color='blue', fontsize=12)\n",
    "ax1.tick_params(axis='y', labelcolor='blue')\n",
    "\n",
    "# Eje Y derecho para Physicians per thousand\n",
    "ax2 = ax1.twinx()\n",
    "ax2.plot(range(len(df_ordenado)), df_ordenado['Physicians per thousand'], \n",
    "         color='red', linewidth=2, marker='s', markersize=4, alpha=0.7)\n",
    "ax2.set_ylabel('Physicians per Thousand', color='red', fontsize=12)\n",
    "ax2.tick_params(axis='y', labelcolor='red')\n",
    "\n",
    "plt.title('Physicians per Thousand vs Life Expectancy (Ejes Diferentes)', \n",
    "          fontsize=16, fontweight='bold')\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Gráfico de dispersión para ver la relación más claramente\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.scatter(df_medicos_vida_limpio['Physicians per thousand'], \n",
    "            df_medicos_vida_limpio['Life expectancy'], \n",
    "            alpha=0.6, color='green')\n",
    "\n",
    "# Agregar línea de tendencia\n",
    "z = np.polyfit(df_medicos_vida_limpio['Physicians per thousand'], \n",
    "               df_medicos_vida_limpio['Life expectancy'], 1)\n",
    "p = np.poly1d(z)\n",
    "plt.plot(df_medicos_vida_limpio['Physicians per thousand'], \n",
    "         p(df_medicos_vida_limpio['Physicians per thousand']), \n",
    "         \"r--\", alpha=0.8, linewidth=2)\n",
    "\n",
    "plt.title('Relación entre Physicians per Thousand y Life Expectancy', \n",
    "          fontsize=16, fontweight='bold')\n",
    "plt.xlabel('Physicians per Thousand', fontsize=12)\n",
    "plt.ylabel('Life Expectancy (años)', fontsize=12)\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Estadísticas y correlación\n",
    "print(\"=== ESTADÍSTICAS Y CORRELACIÓN ===\")\n",
    "print(f\"Datos disponibles: {len(df_medicos_vida_limpio)} países\")\n",
    "print(f\"\\nPhysicians per thousand:\")\n",
    "print(f\"  Media: {df_medicos_vida_limpio['Physicians per thousand'].mean():.3f}\")\n",
    "print(f\"  Desv. Std: {df_medicos_vida_limpio['Physicians per thousand'].std():.3f}\")\n",
    "print(f\"  Rango: {df_medicos_vida_limpio['Physicians per thousand'].min():.3f} - {df_medicos_vida_limpio['Physicians per thousand'].max():.3f}\")\n",
    "\n",
    "print(f\"\\nLife expectancy:\")\n",
    "print(f\"  Media: {df_medicos_vida_limpio['Life expectancy'].mean():.2f}\")\n",
    "print(f\"  Desv. Std: {df_medicos_vida_limpio['Life expectancy'].std():.2f}\")\n",
    "print(f\"  Rango: {df_medicos_vida_limpio['Life expectancy'].min():.2f} - {df_medicos_vida_limpio['Life expectancy'].max():.2f}\")\n",
    "\n",
    "correlacion = df_medicos_vida_limpio['Physicians per thousand'].corr(df_medicos_vida_limpio['Life expectancy'])\n",
    "print(f\"\\nCorrelación: {correlacion:.4f}\")\n",
    "\n",
    "if correlacion > 0.5:\n",
    "    print(\"→ Correlación positiva moderada-fuerte\")\n",
    "elif correlacion > 0.3:\n",
    "    print(\"→ Correlación positiva débil-moderada\")\n",
    "elif correlacion > 0:\n",
    "    print(\"→ Correlación positiva débil\")\n",
    "elif correlacion > -0.3:\n",
    "    print(\"→ Correlación negativa débil\")\n",
    "elif correlacion > -0.5:\n",
    "    print(\"→ Correlación negativa débil-moderada\")\n",
    "else:\n",
    "    print(\"→ Correlación negativa moderada-fuerte\")"
   ]
