   "source": [
    "# Construir gráfico para Population y GDP y convertir a numérico\n",
    "df_pop_gdp_original = df_filtrada[['Population', 'GDP']].copy()\n",
    "\n",
    "\n",
    "print(\"=== ANÁLISIS INICIAL DE DATOS ===\")\n",
    "print(\"Tipos de datos originales:\")\n",
    "print(df_pop_gdp_original.dtypes)\n",
    "print(f\"\\nPrimeros valores:\")\n",
    "print(df_pop_gdp_original.head(10))\n",
    "print(f\"\\nValores nulos:\")\n",
    "print(df_pop_gdp_original.isnull().sum())\n",
    "\n",
    "# Paso 2: Función para limpiar y convertir a numérico\n",
    "def limpiar_convertir_numerico(valor):\n",
    "    \"\"\"\n",
    "    Limpia y convierte valores a numérico\n",
    "    \"\"\"\n",
    "    if pd.isna(valor):\n",
    "        return np.nan\n",
    "    \n",
    "    # Convertir a string y limpiar\n",
    "    valor_str = str(valor)\n",
    "    \n",
    "    # Remover comas, espacios, símbolos de moneda, etc.\n",
    "    valor_limpio = valor_str.replace(',', '').replace('$', '').replace(' ', '').strip()\n",
    "    \n",
    "    # Convertir a numérico\n",
    "    try:\n",
    "        return float(valor_limpio)\n",
    "    except:\n",
    "        return np.nan\n",
    "\n",
    "# Paso 3: Aplicar limpieza a ambas columnas\n",
    "df_pop_gdp_limpio = df_pop_gdp_original.copy()\n",
    "df_pop_gdp_limpio['Population'] = df_pop_gdp_limpio['Population'].apply(limpiar_convertir_numerico)\n",
    "df_pop_gdp_limpio['GDP'] = df_pop_gdp_limpio['GDP'].apply(limpiar_convertir_numerico)\n",
    "\n",
    "print(f\"\\n=== DESPUÉS DE LIMPIEZA ===\")\n",
    "print(\"Tipos de datos después de limpieza:\")\n",
    "print(df_pop_gdp_limpio.dtypes)\n",
    "print(f\"\\nValores nulos después de limpieza:\")\n",
    "print(df_pop_gdp_limpio.isnull().sum())\n",
    "\n",
    "# Paso 4: Eliminar filas con valores nulos\n",
    "df_pop_gdp_final = df_pop_gdp_limpio.dropna()\n",
    "\n",
    "print(f\"\\n=== DATOS FINALES ===\")\n",
    "print(f\"Datos originales: {len(df_pop_gdp_original)}\")\n",
    "print(f\"Datos después de limpieza: {len(df_pop_gdp_limpio)}\")\n",
    "print(f\"Datos finales sin nulos: {len(df_pop_gdp_final)}\")\n",
    "print(f\"Porcentaje conservado: {(len(df_pop_gdp_final)/len(df_pop_gdp_original)*100):.1f}%\")\n",
    "\n",
    "# Paso 5: Estadísticas descriptivas\n",
    "print(f\"\\n=== ESTADÍSTICAS DESCRIPTIVAS ===\")\n",
    "print(\"Population:\")\n",
    "print(f\"  Media: {df_pop_gdp_final['Population'].mean():,.0f}\")\n",
    "print(f\"  Mediana: {df_pop_gdp_final['Population'].median():,.0f}\")\n",
    "print(f\"  Desv. Std: {df_pop_gdp_final['Population'].std():,.0f}\")\n",
    "print(f\"  Mínimo: {df_pop_gdp_final['Population'].min():,.0f}\")\n",
    "print(f\"  Máximo: {df_pop_gdp_final['Population'].max():,.0f}\")\n",
    "\n",
    "print(f\"\\nGDP:\")\n",
    "print(f\"  Media: ${df_pop_gdp_final['GDP'].mean():,.0f}\")\n",
    "print(f\"  Mediana: ${df_pop_gdp_final['GDP'].median():,.0f}\")\n",
    "print(f\"  Desv. Std: ${df_pop_gdp_final['GDP'].std():,.0f}\")\n",
    "print(f\"  Mínimo: ${df_pop_gdp_final['GDP'].min():,.0f}\")\n",
    "print(f\"  Máximo: ${df_pop_gdp_final['GDP'].max():,.0f}\")\n",
    "\n",
    "# Paso 6: Crear gráficos\n",
    "\n",
    "# Gráfico 1: Dispersión con escala normal\n",
    "plt.figure(figsize=(12, 8))\n",
    "plt.scatter(df_pop_gdp_final['Population'], df_pop_gdp_final['GDP'], \n",
    "            alpha=0.6, color='blue', s=50)\n",
    "plt.title('Population vs GDP (Escala Normal)', fontsize=16, fontweight='bold')\n",
    "plt.xlabel('Population', fontsize=12)\n",
    "plt.ylabel('GDP ($)', fontsize=12)\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Gráfico 2: Dispersión con escala logarítmica (recomendado)\n",
    "plt.figure(figsize=(12, 8))\n",
    "plt.scatter(df_pop_gdp_final['Population'], df_pop_gdp_final['GDP'], \n",
    "            alpha=0.6, color='red', s=50)\n",
    "plt.xscale('log')\n",
    "plt.yscale('log')\n",
    "plt.title('Population vs GDP (Escala Logarítmica)', fontsize=16, fontweight='bold')\n",
    "plt.xlabel('Population (escala log)', fontsize=12)\n",
    "plt.ylabel('GDP (escala log)', fontsize=12)\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Gráfico 3: GDP per capita\n",
    "df_pop_gdp_final['GDP per capita'] = df_pop_gdp_final['GDP'] / df_pop_gdp_final['Population']\n",
    "\n",
    "plt.figure(figsize=(12, 8))\n",
    "plt.scatter(df_pop_gdp_final['Population'], df_pop_gdp_final['GDP per capita'], \n",
    "            alpha=0.6, color='green', s=50)\n",
    "plt.xscale('log')\n",
    "plt.title('Population vs GDP per Capita', fontsize=16, fontweight='bold')\n",
    "plt.xlabel('Population (escala log)', fontsize=12)\n",
    "plt.ylabel('GDP per Capita ($)', fontsize=12)\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Paso 7: Análisis de correlación\n",
    "correlacion_pop_gdp = df_pop_gdp_final['Population'].corr(df_pop_gdp_final['GDP'])\n",
    "correlacion_pop_gdp_pc = df_pop_gdp_final['Population'].corr(df_pop_gdp_final['GDP per capita'])\n",
    "\n",
    "print(f\"\\n=== ANÁLISIS DE CORRELACIÓN ===\")\n",
    "print(f\"Correlación Population vs GDP: {correlacion_pop_gdp:.4f}\")\n",
    "print(f\"Correlación Population vs GDP per capita: {correlacion_pop_gdp_pc:.4f}\")\n",
    "\n",
    "# Interpretación de correlaciones\n",
    "def interpretar_correlacion(correlacion):\n",
    "    if abs(correlacion) > 0.7:\n",
    "        return \"Fuerte\"\n",
    "    elif abs(correlacion) > 0.5:\n",
    "        return \"Moderada\"\n",
    "    elif abs(correlacion) > 0.3:\n",
    "        return \"Débil\"\n",
    "    else:\n",
    "        return \"Muy débil\"\n",
    "\n",
    "print(f\"\\nInterpretación:\")\n",
    "print(f\"Population vs GDP: {interpretar_correlacion(correlacion_pop_gdp)} {'positiva' if correlacion_pop_gdp > 0 else 'negativa'}\")\n",
    "print(f\"Population vs GDP per capita: {interpretar_correlacion(correlacion_pop_gdp_pc)} {'positiva' if correlacion_pop_gdp_pc > 0 else 'negativa'}\")\n",
    "\n",
    "# Paso 8: Identificar outliers usando método IQR\n",
    "def identificar_outliers(df, columna):\n",
    "    Q1 = df[columna].quantile(0.25)\n",
    "    Q3 = df[columna].quantile(0.75)\n",
    "    IQR = Q3 - Q1\n",
    "    \n",
    "    limite_inferior = Q1 - 1.5 * IQR\n",
    "    limite_superior = Q3 + 1.5 * IQR\n",
    "    \n",
    "    outliers = df[(df[columna] < limite_inferior) | (df[columna] > limite_superior)]\n",
    "    return outliers, limite_inferior, limite_superior\n",
    "\n",
    "outliers_pop, lim_inf_pop, lim_sup_pop = identificar_outliers(df_pop_gdp_final, 'Population')\n",
    "outliers_gdp, lim_inf_gdp, lim_sup_gdp = identificar_outliers(df_pop_gdp_final, 'GDP')\n",
    "\n",
    "print(f\"\\n=== ANÁLISIS DE OUTLIERS ===\")\n",
    "print(f\"Outliers en Population: {len(outliers_pop)}\")\n",
    "print(f\"Outliers en GDP: {len(outliers_gdp)}\")\n",
    "\n",
    "# Mostrar valores extremos\n",
    "print(f\"\\nValores extremos en Population:\")\n",
    "print(f\"  Límite inferior: {lim_inf_pop:,.0f}\")\n",
    "print(f\"  Límite superior: {lim_sup_pop:,.0f}\")\n",
    "if len(outliers_pop) > 0:\n",
    "    print(f\"  Países con población extrema: {len(outliers_pop)}\")\n",
    "\n",
    "print(f\"\\nValores extremos en GDP:\")\n",
    "print(f\"  Límite inferior: ${lim_inf_gdp:,.0f}\")\n",
    "print(f\"  Límite superior: ${lim_sup_gdp:,.0f}\")\n",
    "if len(outliers_gdp) > 0:\n",
    "    print(f\"  Países con GDP extremo: {len(outliers_gdp)}\")"
   ]
  }
