    "# Parámetros teóricos según TLC\n",
    "media_teorica = p\n",
    "std_teorica = np.sqrt(p * (1-p) / n_muestra)\n",
    "\n",
    "# Función para verificar normalidad\n",
    "def verificar_normalidad(datos, nombre):\n",
    "    print(f\"\\n--- Pruebas de Normalidad - {nombre} ---\")\n",
    "    \n",
    "    # Shapiro-Wilk test\n",
    "    stat_sw, p_sw = shapiro(datos)\n",
    "    print(f\"Shapiro-Wilk: estadístico={stat_sw:.4f}, p-valor={p_sw:.4f}\")\n",
    "    \n",
    "    # Kolmogorov-Smirnov test (comparando con normal teórica)\n",
    "    media_muestral = datos.mean()\n",
    "    std_muestral = datos.std()\n",
    "    datos_normalizados = (datos - media_muestral) / std_muestral\n",
    "    stat_ks, p_ks = kstest(datos_normalizados, 'norm')\n",
    "    print(f\"Kolmogorov-Smirnov: estadístico={stat_ks:.4f}, p-valor={p_ks:.4f}\")\n",
    "    \n",
    "    # D'Agostino's normality test\n",
    "    stat_da, p_da = normaltest(datos)\n",
    "    print(f\"D'Agostino-Pearson: estadístico={stat_da:.4f}, p-valor={p_da:.4f}\")\n",
    "    \n",
    "    return p_sw, p_ks, p_da\n",
    "\n",
    "# Verificar normalidad para ambas distribuciones\n",
    "print(\"VERIFICACIÓN DEL TEOREMA DEL LÍMITE CENTRAL\")\n",
    "print(f\"Parámetros teóricos: μ={media_teorica:.4f}, σ={std_teorica:.4f}\")\n",
    "\n",
    "# Pruebas para simulación binomial\n",
    "p_sw_sim, p_ks_sim, p_da_sim = verificar_normalidad(medias_muestrales_sim, \"Simulación Binomial\")\n",
    "\n",
    "# Pruebas para muestreo real\n",
    "p_sw_real, p_ks_real, p_da_real = verificar_normalidad(medias_muestrales_reales, \"Muestreo Real\")"
   ]
