    "# Parámetros\n",
    "p = 0.3910  # probabilidad de fumar\n",
    "n_muestra = 8  # tamaño de cada muestra\n",
    "n_simulaciones = 1000  # número de muestras a simular\n",
    "\n",
    "# Simular 1000 muestras de tamaño 8 desde la distribución binomial\n",
    "muestras_simuladas = binom.rvs(n=1, p=p, size=(n_simulaciones, n_muestra))\n",
    "\n",
    "# Calcular medias muestrales (proporción de fumadoras en cada muestra)\n",
    "medias_muestrales_sim = muestras_simuladas.mean(axis=1)\n",
    "\n",
    "# Mostrar resultados\n",
    "print(f\"Se simularon {n_simulaciones} muestras de tamaño {n_muestra}\")\n",
    "print(f\"Primeras 10 medias muestrales: {medias_muestrales_sim[:10]}\")\n",
    "print(f\"Media de las medias muestrales: {medias_muestrales_sim.mean():.4f}\")\n",
    "print(f\"Desviación estándar de las medias: {medias_muestrales_sim.std():.4f}\")\n",
    "\n",
    "# Comparar con valores teóricos\n",
    "media_teorica = p\n",
    "error_tipico_teorico = np.sqrt(p * (1-p) / n_muestra)\n",
    "print(f\"\\nValores teóricos:\")\n",
    "print(f\"Media teórica: {media_teorica:.4f}\")\n",
    "print(f\"Error típico teórico: {error_tipico_teorico:.4f}\")"
